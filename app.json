{
  "expo": {
    "name": "mealio",
    "slug": "mealio",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mealio",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.frandka.mealio",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "我们需要您的位置来显示附近的餐厅和按距离筛选。",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "我们需要您的位置来持续更新附近的餐厅信息（如果需要后台定位）。",
        "NSLocationAlwaysUsageDescription": "我们需要您的位置来在后台持续更新附近的餐厅信息（如果需要后台定位）。"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.frandka.mealio",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "我们需要您的位置来显示附近的餐厅和按距离筛选（包括应用在后台时，如果您启用了相关功能）。",
          "locationWhenInUsePermission": "我们需要您的位置来显示附近的餐厅和按距离筛选。"
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6cd392eb-e289-42bd-9674-8ad1b581c360"
      }
    }
  }
}
